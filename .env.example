# TeaOps Agent Supervisor (teaops-agentd) configuration

# Path to the teaops-agent binary that agentd supervises.
TEAOPS_AGENT_BIN=./teaops-agent

# Shared runtime directory for pid/heartbeat/lock files (both agentd and agent).
TEAOPS_RUNTIME_DIR=.

# How long (seconds) without a heartbeat before a peer is considered dead.
TEAOPS_HEARTBEAT_TIMEOUT_SECS=15

# How often (seconds) agentd checks the supervised agent.
TEAOPS_SUPERVISE_INTERVAL_SECS=3

# Minimum delay (seconds) between agent restarts (avoids restart storms).
TEAOPS_RESTART_BACKOFF_SECS=2

# --- Binary source (for re-fetching a missing/deleted agent binary) ---
# Tried GitHub-first, then the download service as a fallback.
TEAOPS_AGENT_REPO=simonsmithmd/Teaops-agent
TEAOPS_DOWNLOAD_URL=https://download.agent.dn7.cn

# Logging
RUST_LOG=info,teaops_agentd=info
